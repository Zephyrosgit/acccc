@echo off
chcp 65001 > nul
title 모던 멀티링크 웹앱 실행기
echo ====================================================
echo   안티그래비티 v2.1.4 멀티링크 로컬 서버 실행기
echo ====================================================
echo.
echo   1. 로컬 개발 서버(npm run dev)를 시작합니다.
echo   2. 브라우저에서 테스트 페이지(http://localhost:3000)를 엽니다.
echo.
echo ====================================================
echo.

:: 배치 파일이 위치한 경로로 작업 디렉토리를 이동합니다.
cd /d "%~dp0"

:: 3초 후에 브라우저가 열리도록 약간의 딜레이 후 접속 주소를 엽니다.
start http://localhost:3000

:: Next.js 개발 서버를 실행합니다.
npm run dev

pause
